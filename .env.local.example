# Copy this to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # server-only, never expose to client

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                             # server-only, never expose to client

# ── OpenAI (DALL-E 3 image generation) ────────────────────────────────────────
OPENAI_API_KEY=sk-...                                    # server-only, never expose to client

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                                      # server-only
RESEND_FROM_EMAIL=Boss Daddy <hello@bossdaddylife.com>     # update after domain verified in Resend

# ── Upstash Redis (rate limiting on Claude endpoints) ─────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Internal API secret (protects /api/claude/moderate from external calls) ───
INTERNAL_API_SECRET=generate-with-openssl-rand-hex-32

# ── Cron secret (protects /api/cron/* from unauthenticated invocation) ────────
# Vercel Cron sends this as a Bearer token automatically when configured here.
# REQUIRED — the cron endpoint refuses to run if this is unset (fail-closed).
CRON_SECRET=generate-with-openssl-rand-hex-32

# ── Sentry (optional — production error monitoring) ───────────────────────────
# Set NEXT_PUBLIC_SENTRY_DSN to activate Sentry. Leave unset locally to skip.
# Create a free project at sentry.io, copy the DSN from Project Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=
# These three are only needed for source map uploads in production builds.
# Generate the auth token at sentry.io → User Settings → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
