  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.13.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.7"
  },
  "browserslist": [
    "Chrome >= 100",
    "Edge >= 100",
    "Firefox >= 100",
    "Safari >= 15.4",
    "iOS >= 15.4",
    "not dead",
    "not op_mini all"
  ]
