{
  "name": "bossdaddy-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/check-middleware-convention.mjs",
    "build": "next build",
    "prebuild": "node scripts/check-middleware-convention.mjs && node scripts/check-og-coverage.mjs",
    "start": "next start",
    "lint": "eslint",
    "check": "tsc --noEmit && eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:middleware": "node scripts/check-middleware-convention.mjs",
    "check:og": "node scripts/check-og-coverage.mjs",
    "db:types": "node scripts/gen-types.mjs",
    "db:push": "supabase db push",
    "test:rls": "supabase test db",
    "smoke": "node --env-file=.env.local scripts/smoke-test.mjs",
    "merch:sync": "node --env-file=.env.local scripts/sync-printful.mjs",
    "merch:discover": "node --env-file=.env.local scripts/discover-merch-blanks.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-character-count": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/web-push": "^3.6.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "require-in-the-middle": "^8.0.1",
    "resend": "^6.12.0",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
